# По умолчанию API идёт через прокси Next.js (/api-proxy → 127.0.0.1:4000).
# Раскомментируйте только если нужен прямой URL (отдельный домен API):
# NEXT_PUBLIC_API_URL=https://api.example.com/api

# Для docker-compose сервиса web (куда контейнер Next проксирует запросы):
# BACKEND_INTERNAL_URL=http://api:4000
